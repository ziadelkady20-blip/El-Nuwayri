// Firebase Storage Security Rules - مطبعة النويري
// انسخ هذا إلى Firebase Console > Storage > Rules

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Public read for all images
    match /{allPaths=**} {
      allow read: if true;
    }

    // Only authenticated admins can upload/delete
    match /products/{filename} {
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /portfolio/{filename} {
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /media/{filename} {
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
