// ============================================================
// Firestore Security Rules - مطبعة النويري
// انسخ هذا إلى Firebase Console > Firestore > Rules
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated admin
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function getRole() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role;
    }

    function isSuperAdmin() {
      return isAdmin() && getRole() == 'superadmin';
    }

    function isManagerOrAbove() {
      return isAdmin() && getRole() in ['superadmin', 'manager'];
    }

    // Public site content - anyone can read, only admins can write
    match /site/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories - public read, admin write
    match /categories/{id} {
      allow read: if true;
      allow write: if isManagerOrAbove();
    }

    // Products - public read, manager+ write
    match /products/{id} {
      allow read: if true;
      allow write: if isManagerOrAbove();
    }

    // Portfolio - public read, admin write
    match /portfolio/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Testimonials - public read, admin write
    match /testimonials/{id} {
      allow read: if resource.data.active == true;
      allow write: if isAdmin();
    }

    // Orders - anyone can CREATE (contact form), only admins can read/update
    match /orders/{id} {
      allow create: if true;
      allow read, update: if isManagerOrAbove();
      allow delete: if isSuperAdmin();
    }

    // Activity log - admin read/write
    match /activity/{id} {
      allow read: if isAdmin();
      allow create: if true; // system creates these
      allow update, delete: if isSuperAdmin();
    }

    // Admin users - only super admin can manage
    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }
  }
}
